---
const footerLinks = {
  product: [
    { label: "Features", href: "/#features" },
    { label: "Roadmap", href: "/#roadmap" },
    { label: "Pricing", href: "/#pricing" },
    { label: "FAQ", href: "/#faq" },
    { label: "Press Kit", href: "/press-kit" },
  ],
  resources: [
    { label: "Documentation", href: "/docs" },
    { label: "Links", href: "/links" },
    { label: "Changelog", href: "/docs/changelog" },
    { label: "Blog", href: "/blog" },
    { label: "Support", href: "mailto:support@gdagent.dev" },
  ],
  legal: [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
    { label: "Refund Policy", href: "/refund" },
    { label: "Imprint", href: "/imprint" },
  ],
};

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[#262626] py-10 md:py-11">
  <div class="mx-auto max-w-6xl px-6">
    <div class="anim anim-fade-up grid gap-8 md:grid-cols-4">
      <div>
        <a href="/">
          <img
            src="/images/gdagent transparent.svg"
            alt="GDAgent™"
            width="150"
            height="32"
            class="h-8 w-auto"
          />
        </a>
        <p class="mt-3 text-sm text-[#a1a1a1]">
          The Professional AI Development<br />Environment for Godot
        </p>
      </div>

      <div>
        <p class="mb-4 font-mono text-sm font-medium text-[#a1a1a1]">Product</p>
        <ul class="m-0 list-none space-y-2 p-0">
          {footerLinks.product.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white no-underline transition-colors hover:text-[#a1a1a1]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-4 font-mono text-sm font-medium text-[#a1a1a1]">Resources</p>
        <ul class="m-0 list-none space-y-2 p-0">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white no-underline transition-colors hover:text-[#a1a1a1]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-4 font-mono text-sm font-medium text-[#a1a1a1]">Legal</p>
        <ul class="m-0 list-none space-y-2 p-0">
          {footerLinks.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white no-underline transition-colors hover:text-[#a1a1a1]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-[#262626] pt-6 md:flex-row">
      <p class="text-sm text-[#a1a1a1]">
        &copy; {currentYear} GDAgent™ Team.
      </p>
      <div class="flex gap-4">
        <a
          href="https://x.com/GDAgentDev"
          data-umami-event="social-x"
          class="text-[#a1a1a1] transition-colors hover:text-white"
          aria-label="Twitter / X"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a
          href="https://bsky.app/profile/gdagentdev.bsky.social"
          data-umami-event="social-bluesky"
          class="text-[#a1a1a1] transition-colors hover:text-white"
          aria-label="Bluesky"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037-.856 3.061-3.978 3.842-6.755 3.37 4.854.826 6.089 3.562 3.422 6.299-5.065 5.196-7.28-1.304-7.847-2.97-.104-.305-.152-.448-.153-.327 0-.121-.05.022-.153.327-.568 1.666-2.782 8.166-7.847 2.97-2.667-2.737-1.432-5.473 3.422-6.3-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026"/>
          </svg>
        </a>
        <a
          href="https://youtube.com/@GDAgentDev"
          data-umami-event="social-youtube"
          class="text-[#a1a1a1] transition-colors hover:text-white"
          aria-label="YouTube"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
        </a>
        <a
          href="https://discord.gg/y5rrsQDpDg"
          data-umami-event="social-discord"
          class="text-[#a1a1a1] transition-colors hover:text-white"
          aria-label="Discord"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.317 4.3698a19.791 19.791 0 0 0-4.8851-1.5152.0742.0742 0 0 0-.0785.0371c-.2112.3753-.4447.8648-.6083 1.2495a18.27 18.27 0 0 0-5.487 0c-.1637-.3928-.4058-.8742-.6083-1.2495a.077.077 0 0 0-.0785-.037 19.736 19.736 0 0 0-4.885 1.5152.07.07 0 0 0-.0321.0277C.5334 9.0467-.3205 13.5799.0997 18.0578a.0824.0824 0 0 0 .0312.0561 19.9 19.9 0 0 0 5.9932 3.03.0789.0789 0 0 0 .0842-.0276 13.83 13.83 0 0 0 1.226-1.9942.076.076 0 0 0-.0416-.1057 13.107 13.107 0 0 1-1.872-.8923.077.077 0 0 1-.0076-.1277c.1258-.0943.2518-.1947.3726-.2976a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.061 0a.0743.0743 0 0 1 .0785.0094c.1208.103.2468.2044.3735.2987a.077.077 0 0 1-.0067.1276 12.299 12.299 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067 16.037 16.037 0 0 0 1.226 1.9933.077.077 0 0 0 .0842.0286 19.876 19.876 0 0 0 6.002-3.03.077.077 0 0 0 .0313-.0552c.5003-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.0312-.0286zM8.02 15.3312c-1.1822 0-2.1552-1.0857-2.1552-2.419 0-1.3333.9543-2.419 2.1552-2.419 1.209 0 2.1735 1.0952 2.1553 2.419 0 1.3333-.9462 2.419-2.1553 2.419zm7.974 0c-1.1822 0-2.1552-1.0857-2.1552-2.419 0-1.3333.9543-2.419 2.1552-2.419 1.209 0 2.1735 1.0952 2.1553 2.419 0 1.3333-.9462 2.419-2.1553 2.419z" />
          </svg>
        </a>
        <a
          href="https://reddit.com/r/GDAgent"
          data-umami-event="social-reddit"
          class="text-[#a1a1a1] transition-colors hover:text-white"
          aria-label="Reddit"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.373 0 0 5.373 0 12c0 3.314 1.343 6.314 3.515 8.485l-2.286 2.286C.775 23.225 1.097 24 1.738 24H12c6.627 0 12-5.373 12-12S18.627 0 12 0Zm4.388 3.199c1.104 0 1.999.895 1.999 1.999 0 1.105-.895 2-1.999 2-.946 0-1.739-.657-1.947-1.539v.002c-1.147.162-2.032 1.15-2.032 2.341v.007c1.776.067 3.4.567 4.686 1.363.473-.363 1.064-.58 1.707-.58 1.547 0 2.802 1.254 2.802 2.802 0 1.117-.655 2.081-1.601 2.531-.088 3.256-3.637 5.876-7.997 5.876-4.361 0-7.905-2.617-7.998-5.87-.954-.447-1.614-1.415-1.614-2.538 0-1.548 1.255-2.802 2.803-2.802.645 0 1.239.218 1.712.585 1.275-.79 2.881-1.291 4.64-1.365v-.01c0-1.663 1.263-3.034 2.88-3.207.188-.911.993-1.595 1.959-1.595Zm-8.085 8.376c-.784 0-1.459.78-1.506 1.797-.047 1.016.64 1.429 1.426 1.429.786 0 1.371-.369 1.418-1.385.047-1.017-.553-1.841-1.338-1.841Zm7.406 0c-.786 0-1.385.824-1.338 1.841.047 1.017.634 1.385 1.418 1.385.785 0 1.473-.413 1.426-1.429-.046-1.017-.721-1.797-1.506-1.797Zm-3.703 4.013c-.974 0-1.907.048-2.77.135-.147.015-.241.168-.183.305.483 1.154 1.622 1.964 2.953 1.964 1.33 0 2.47-.81 2.953-1.964.057-.137-.037-.29-.184-.305-.863-.087-1.795-.135-2.769-.135Z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-6">
      <p class="text-[10px] uppercase tracking-[0.2em] text-[#808080]">
        Brands are the property of their respective owners.
      </p>
    </div>
  </div>
</footer>
