---
import { TEAM_WAITLIST_URL, MACOS_WAITLIST_URL } from "../utils/waitlist";

const plans = [
  {
    name: "Individual",
    price: "$9.99",
    description: "Perfect for solo developers",
    features: [
      { label: "Machines", value: "2" },
      { label: "Updates", value: "Unlimited while maintained" },
      { label: "Support", value: "Email" },
    ],
    cta: "Buy Individual",
    href: "https://gdagent.lemonsqueezy.com/checkout/buy/c0dae998-2713-48fd-99af-5943a58ad9b4",
    highlighted: true,
    comingSoon: false,
  },
  {
    name: "Team",
    price: "$199",
    description: "For studios and teams (coming soon)",
    features: [
      { label: "Machines", value: "10" },
      { label: "Updates", value: "Unlimited while maintained" },
      { label: "Support", value: "Priority" },
    ],
    cta: "Join the Waitlist",
    href: "",
    highlighted: false,
    comingSoon: true,
  },
];
---

<section id="pricing" class="py-16 md:py-20">
  <div class="mx-auto max-w-4xl px-6">
    <div class="anim anim-fade-up mb-12 text-center">
      <h2 class="mb-4 font-mono text-3xl font-medium tracking-tight md:text-4xl">
        Simple Pricing
      </h2>
      <p class="mb-4 text-[#a1a1a1]">
        One-time purchase. No subscriptions. Unlimited updates while maintained.
      </p>
    </div>

    <div class="anim anim-fade-up anim-d1 mb-12 rounded-lg border border-[#27ca40]/30 bg-[#27ca40]/10 p-6 md:p-8">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <h3 class="mb-2 font-mono text-xl font-medium text-white">Start With A Free Trial</h3>
          <p class="text-[#a1a1a1]">
            Run the full version for 7 days. No credit card required.
          </p>
        </div>
        <div class="flex flex-col items-start gap-4 md:items-center text-left md:text-center">
          <div class="flex flex-col items-center leading-tight">
            <span class="text-xs font-medium uppercase tracking-widest text-[#a1a1a1]">full access for</span>
            <span class="font-mono text-4xl font-medium text-white">7 <span class="text-3xl">days</span></span>
          </div>
          <a
            href="https://gdagent.lemonsqueezy.com/checkout/buy/e364be1b-0edc-47b3-86d5-a28f4b9ed24f"
            data-umami-event="cta-trial"
            class="inline-flex items-center gap-2 rounded border border-[#27ca40] bg-[#27ca40] px-12 py-2.5 text-sm font-medium text-[#0a0a0a] no-underline whitespace-nowrap transition-colors hover:bg-[#27ca40]/90"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Start Free Trial
          </a>
        </div>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {plans.map((plan, i) => (
        <div
          class:list={[
            `anim anim-fade-up anim-d${i + 2} flex flex-col rounded-lg border p-6 transition-colors`,
            plan.highlighted
              ? "border-white bg-[#121212]"
              : "border-[#262626] bg-[#121212] hover:border-[#404040]",
          ]}
        >
          <div class="mb-6 min-h-[4rem]">
            <h3 class="mb-1 font-mono text-xl font-medium">{plan.name}</h3>
            <p class="text-sm text-[#a1a1a1]">{plan.description}</p>
          </div>

          <div class="mb-6 min-h-[6rem]">
            {plan.comingSoon ? (
              <span class="font-mono text-2xl font-medium text-[#a1a1a1]">Coming soon</span>
            ) : (
              <div class="flex items-baseline gap-2">
                <span class="font-mono text-4xl font-medium" data-price-current>{plan.price}</span>
                <span class="text-[#a1a1a1]">one-time</span>
              </div>
            )}
          </div>

          <ul class="mb-6 flex-1 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex justify-between text-sm">
                <span class="text-[#a1a1a1]">{feature.label}</span>
                <span class="font-mono">{feature.value}</span>
              </li>
            ))}
          </ul>

          {plan.comingSoon ? (
            TEAM_WAITLIST_URL ? (
              <a
                href={TEAM_WAITLIST_URL}
                data-umami-event="cta-team-waitlist"
                class="flex items-center justify-center gap-2 rounded border border-[#262626] py-3 text-center font-medium text-white no-underline transition-colors hover:border-white"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                {plan.cta}
              </a>
            ) : (
              <span class="flex items-center justify-center gap-2 rounded border border-[#262626] bg-[#0a0a0a] py-3 text-center font-medium text-[#a1a1a1]">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Coming Soon
              </span>
            )
          ) : (
            <a
              href={plan.href}
              data-umami-event="cta-buy"
              class:list={[
                "flex items-center justify-center gap-2 rounded border py-3 text-center font-medium no-underline transition-colors",
                plan.highlighted
                  ? "border-white bg-white text-[#0a0a0a] hover:bg-[#f0f0f0] hover:text-[#0a0a0a]"
                  : "border-[#262626] text-white hover:border-white",
              ]}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              {plan.cta}
            </a>
          )}
        </div>
      ))}
    </div>

    <div class="anim anim-fade-in anim-d4 mt-8 flex flex-col items-center gap-3 text-center">
      <p class="inline-flex items-center gap-2 rounded-full border border-[#27ca40]/40 bg-[#27ca40]/10 px-4 py-1.5 text-sm font-medium text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#27ca40" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
        30-day money-back guarantee — buy with zero risk. <a href="/refund" class="underline hover:text-[#a1a1a1]">Refund Policy</a>
      </p>
      <p class="text-sm text-[#a1a1a1]">
        Available for <span class="text-white">Windows &amp; Linux</span>. On macOS?{" "}
        {MACOS_WAITLIST_URL ? (
          <a href={MACOS_WAITLIST_URL} data-umami-event="cta-macos-waitlist-pricing" class="font-medium text-[#27ca40] no-underline hover:opacity-80">Join the waitlist →</a>
        ) : (
          <span>macOS support is planned.</span>
        )}{" "}
        · Android is planned.
      </p>
    </div>
  </div>
</section>
