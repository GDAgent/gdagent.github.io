---
const agents = [
  { name: "Claude Code", icon: "https://cdn.simpleicons.org/claude/white" },
  { name: "Google Antigravity CLI", icon: "https://cdn.simpleicons.org/google/white" },
  { name: "Aider", icon: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 15 15'%3E%3Crect x='3.5' y='0' width='2' height='3' fill='white'/%3E%3Crect x='5.5' y='0' width='2' height='3' fill='white'/%3E%3Crect x='7.5' y='0' width='2' height='3' fill='white'/%3E%3Crect x='9.5' y='3' width='2' height='3' fill='white'/%3E%3Crect x='3.5' y='6' width='2' height='3' fill='white'/%3E%3Crect x='5.5' y='6' width='2' height='3' fill='white'/%3E%3Crect x='7.5' y='6' width='2' height='3' fill='white'/%3E%3Crect x='9.5' y='6' width='2' height='3' fill='white'/%3E%3Crect x='1.5' y='9' width='2' height='3' fill='white'/%3E%3Crect x='9.5' y='9' width='2' height='3' fill='white'/%3E%3Crect x='3.5' y='12' width='2' height='3' fill='white'/%3E%3Crect x='5.5' y='12' width='2' height='3' fill='white'/%3E%3Crect x='7.5' y='12' width='2' height='3' fill='white'/%3E%3Crect x='11.5' y='12' width='2' height='3' fill='white'/%3E%3C/svg%3E" },
  { name: "GitHub Copilot CLI", icon: "https://cdn.simpleicons.org/githubcopilot/white" },
  { name: "Mistral Vibe", icon: "https://cdn.simpleicons.org/mistralai/white" },
  { name: "OpenAI Codex CLI", icon: "https://api.iconify.design/simple-icons/openai.svg?color=white" },
  { name: "OpenCode", icon: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='96 64 320 384' fill='none'%3E%3Cpath d='M320 224V352H192V224H320Z' fill='white' opacity='0.4'/%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M384 416H128V96H384V416ZM320 160H192V352H320V160Z' fill='white'/%3E%3C/svg%3E" },
];
---

<section class="relative pt-24 pb-16 md:pt-32 md:pb-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center text-center">
      <!-- Headline -->
      <h1 class="anim anim-fade-up mb-6 font-mono text-4xl font-medium tracking-tight md:text-5xl lg:text-6xl">
        Native AI terminals &amp;<br />
        multi-agent layouts,<br />
        <span class="text-[#a1a1a1]">in Godot.</span>
      </h1>

      <!-- Subheadline -->
      <p class="anim anim-fade-up anim-d1 mb-8 max-w-2xl text-lg text-[#a1a1a1]">
        Run the coding agents you already use — several at once, organized your way — without leaving the editor.
      </p>

      <!-- CTAs -->
      <div class="anim anim-fade-up anim-d2 mb-3 flex flex-col gap-4 sm:flex-row">
        <a
          href="https://gdagent.lemonsqueezy.com/checkout/buy/e364be1b-0edc-47b3-86d5-a28f4b9ed24f"
          data-umami-event="hero-trial"
          class="inline-flex items-center justify-center gap-2 rounded border border-white bg-white px-8 py-3 font-medium text-[#0a0a0a] no-underline transition-colors hover:bg-[#f0f0f0] hover:text-[#0a0a0a]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Start free trial
        </a>
        <a
          href="https://gdagent.lemonsqueezy.com/checkout/buy/c0dae998-2713-48fd-99af-5943a58ad9b4"
          data-umami-event="hero-buy"
          class="inline-flex items-center justify-center gap-2 rounded border border-[#262626] px-8 py-3 font-medium text-white no-underline transition-colors hover:border-white"
        >
          Buy — $9.99
        </a>
      </div>

      <!-- Reassurance + demo link -->
      <p class="anim anim-fade-up anim-d2 mb-3 text-sm text-[#a1a1a1]">
        Free 7-day trial · $9.99 one-time, no subscription · your code never leaves your machine
      </p>
      <a
        href="#demo"
        data-umami-event="hero-watch-demo"
        class="anim anim-fade-up anim-d2 mb-12 inline-flex items-center gap-1.5 text-sm text-[#a1a1a1] no-underline transition-colors hover:text-white"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Watch the 90-second demo
      </a>

      <!-- Agent badges -->
      <div class="anim anim-fade-up anim-d3 mb-16 flex w-full flex-col items-center gap-3">
        <span class="text-sm text-[#a1a1a1]">Works with:</span>
        <div class="mx-auto flex flex-col items-center gap-2.5 xs:max-w-[330px] xs:flex-row xs:flex-wrap xs:justify-center sm:max-w-[430px] md:max-w-[620px] xl:max-w-none">
          {agents.map((agent) => (
            <div
              class="group flex items-center gap-2 rounded-full border border-[#262626] bg-[#121212] px-3.5 py-2 transition-all duration-200 hover:border-[#525252] hover:bg-[#1a1a1a]"
            >
              <div class="flex h-4 w-4 shrink-0 items-center justify-center">
                <img
                  src={agent.icon}
                  alt=""
                  width="16"
                  height="16"
                  class="max-h-4 max-w-4 opacity-60 transition-opacity duration-200 group-hover:opacity-100"
                  loading="lazy"
                />
              </div>
              <span class="whitespace-nowrap text-[13px] text-[#a1a1a1] transition-colors duration-200 group-hover:text-white">
                {agent.name}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Hero media -->
      <div class="anim anim-scale-in anim-d4 w-full max-w-5xl">
        <div class="overflow-hidden rounded-xl border border-[#262626] bg-[#121212]">
          <img
            src="/images/hero-screenshot-1400.webp"
            srcset="/images/hero-screenshot-960.webp 960w, /images/hero-screenshot-1400.webp 1400w, /images/hero-screenshot-1854.webp 1854w"
            sizes="(max-width: 640px) 92vw, (max-width: 1024px) 90vw, 1200px"
            alt="GDAgent interface showing AI-assisted Godot development"
            width="1854"
            height="1009"
            class="block h-auto w-full"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>
