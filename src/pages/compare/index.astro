---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { comparisons } from "../../data/comparisons";
---

<Base
  title="Compare GDAgent — vs. Ziva, Summer Engine & free plugins"
  description="Honest comparisons of GDAgent with other Godot AI tools: Ziva, Summer Engine, and the free open-source plugins. What GDAgent does better, and where each alternative wins."
>
  <Nav />
  <main class="pt-24">
    <div class="mx-auto max-w-3xl px-6 py-16">
      <h1 class="anim anim-fade-up font-mono text-4xl font-medium tracking-tight">How GDAgent compares</h1>
      <p class="anim anim-fade-up anim-d1 mt-4 max-w-2xl text-[#a1a1a1]">
        Straight comparisons with the other ways to use AI in Godot. Each one leads with where GDAgent is stronger and is honest about where the alternative wins.
      </p>

      <div class="mt-10 space-y-4">
        {comparisons.map((c, i) => (
          <a
            href={`/compare/${c.slug}`}
            class={`anim anim-fade-up anim-d${i + 2} block rounded-lg border border-[#262626] bg-[#121212] p-6 no-underline transition-colors hover:border-[#404040]`}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="font-mono text-lg font-medium text-white">{c.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-[#a1a1a1]">{c.shortVersion}</p>
              </div>
              <span class="pt-0.5 text-[#808080]">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
