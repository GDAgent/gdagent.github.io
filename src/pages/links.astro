---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const groups = [
  {
    title: "Feedback & Support",
    links: [
      {
        label: "GitHub Issues",
        href: "https://github.com/GDAgent/GDAgent/issues",
        description: "Report bugs, request features, and track product issues.",
      },
      {
        label: "Support Email",
        href: "mailto:support@gdagent.dev",
        description: "Contact support directly for installation, licensing, or account help.",
      },
      {
        label: "Documentation",
        href: "/docs",
        description: "Browse setup guides, troubleshooting, and reference docs.",
      },
    ],
  },
  {
    title: "Socials",
    links: [
      {
        label: "Discord",
        href: "https://discord.gg/y5rrsQDpDg",
        description: "Community chat and discussion.",
      },
      {
        label: "YouTube",
        href: "https://youtube.com/@GDAgentDev",
        description: "Demos, walkthroughs, and updates.",
      },
      {
        label: "Bluesky",
        href: "https://bsky.app/profile/gdagentdev.bsky.social",
        description: "Release notes and smaller updates.",
      },
      {
        label: "Reddit",
        href: "https://reddit.com/r/GDAgent",
        description: "Community posts and discussion.",
      },
    ],
  },
];
---

<Base
  title="Links — GDAgent"
  description="Official links for GDAgent support, issue reporting, and social channels."
>
  <Nav />
  <main class="pt-24">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <h1 class="anim anim-fade-up mb-4 font-mono text-4xl font-medium tracking-tight">Links</h1>
      <p class="anim anim-fade-up anim-d1 mb-12 max-w-2xl text-[#a1a1a1]">
        Official places to get support, report issues, and follow GDAgent.
      </p>

      <div class="space-y-10">
        {groups.map((group, groupIndex) => (
          <section class={`anim anim-fade-up anim-d${groupIndex + 2}`}>
            <h2 class="mb-4 font-mono text-xl font-medium">{group.title}</h2>
            <div class="grid gap-4 sm:grid-cols-2">
              {group.links.map((link) => {
                const external = link.href.startsWith("http") || link.href.startsWith("mailto:");
                return (
                  <a
                    href={link.href}
                    target={external && !link.href.startsWith("mailto:") ? "_blank" : undefined}
                    rel={external && !link.href.startsWith("mailto:") ? "noopener noreferrer" : undefined}
                    class="group rounded-lg border border-[#262626] bg-[#121212] p-5 no-underline transition-colors hover:border-[#404040]"
                  >
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <h3 class="font-mono text-base font-medium text-white">{link.label}</h3>
                        <p class="mt-2 text-sm leading-relaxed text-[#a1a1a1]">{link.description}</p>
                      </div>
                      <span class="pt-0.5 text-[#808080] transition-colors group-hover:text-white">→</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
