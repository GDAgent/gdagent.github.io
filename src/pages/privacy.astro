---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PrivacyPolicyDe from "../components/legal/PrivacyPolicyDe.astro";
---

<Base
  title="Privacy Policy — GDAgent"
  description="Read how GDAgent handles personal data for website hosting, license purchases, and support communication under GDPR-compliant policies."
>
  <Nav />
  <main class="pt-24">
    <div class="mx-auto max-w-3xl px-6 py-16">
      <h1 id="privacy-title" class="mb-3 font-mono text-4xl font-medium tracking-tight">Privacy Policy</h1>
      <div class="mb-6 flex items-center gap-2 text-[10px] uppercase tracking-[0.18em] text-[#666666]">
        <button
          type="button"
          data-policy-switch="en"
          class="text-[#a1a1a1] transition-colors hover:text-white"
          aria-pressed="true"
        >
          EN
        </button>
        <span>/</span>
        <button
          type="button"
          data-policy-switch="de"
          class="transition-colors hover:text-white"
          aria-pressed="false"
        >
          DE
        </button>
      </div>
      <p id="privacy-updated" class="mb-4 text-sm text-[#a1a1a1]">Last Updated: 2026-06-23</p>

      <div id="privacy-content-en" data-policy-lang="en" class="prose prose-invert max-w-none space-y-6 text-[#a1a1a1]">
        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">1. Data Controller</h2>
          <p>
            <strong>Björn Feber</strong><br />
            Kiebitzweg 36<br />
            48496 Hopsten<br />
            Germany
          </p>
          <p>
            Email: <a href="mailto:info@gdagent.dev" class="text-white hover:underline">info@gdagent.dev</a>
          </p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">2. Overview</h2>
          <p>This Privacy Policy explains how we process personal data in connection with:</p>
          <ul>
            <li>The GDAgent website at <a href="https://gdagent.dev" class="text-white hover:underline" target="_blank" rel="noopener">https://gdagent.dev</a> (the "Website")</li>
            <li>The GDAgent software plugin for the Godot Engine (the "Software")</li>
          </ul>
          <p>We process personal data in accordance with the GDPR and applicable German data protection law.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">3. Data Processing by the Software</h2>
          <p><strong>GDAgent does not use analytics or advertising trackers and does not send your project files to us.</strong></p>
          <p>License activation and validation may involve license-related data such as your license key, activation status, and a device or instance identifier. These data are used only for licensing and support purposes.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">4. Website Hosting (GitHub Pages)</h2>
          <p>Our Website is hosted on <strong>GitHub Pages</strong>. When you visit the Website, GitHub may process technical data in server logs, including:</p>
          <ul>
            <li>Your IP address</li>
            <li>Browser type and version</li>
            <li>Operating system</li>
            <li>Referring URL</li>
            <li>Date and time of access</li>
            <li>Pages visited</li>
          </ul>
          <p>This processing is necessary to provide the Website. The legal basis is Art. 6(1)(f) GDPR. GitHub's privacy information is available at <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" class="text-white hover:underline" target="_blank" rel="noopener">GitHub Privacy Statement</a>.</p>
          <p>GitHub is based in the United States. Where required, international transfers are made using appropriate safeguards under Art. 44 et seq. GDPR.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">5. Purchases and License Activation (Lemon Squeezy)</h2>
          <p>Purchases and license activation are handled through <strong>Lemon Squeezy</strong>, which acts as merchant of record. Depending on the transaction, Lemon Squeezy may process:</p>
          <ul>
            <li>Your name and email address</li>
            <li>Payment and billing information</li>
            <li>Order, license, and activation information</li>
            <li>Device or instance information used for license activation</li>
          </ul>
          <p><strong>Legal basis:</strong> Art. 6(1)(b) GDPR.</p>
          <p>We may receive limited data from Lemon Squeezy, such as your email address, order information, and license status, where needed for licensing and support. Lemon Squeezy's privacy information is available at <a href="https://www.lemonsqueezy.com/privacy" class="text-white hover:underline" target="_blank" rel="noopener">Lemon Squeezy Privacy Policy</a>.</p>
          <p>Lemon Squeezy is based in the United States. Where required, international transfers are made using appropriate safeguards under Art. 44 et seq. GDPR.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">6. Sources of Personal Data</h2>
          <p>We receive personal data either directly from you or indirectly from Lemon Squeezy.</p>
          <ul>
            <li><strong>Directly from you</strong>, for example when you email us.</li>
            <li><strong>Indirectly from Lemon Squeezy</strong>, for example purchase, trial, license, activation, or related subscription information linked to your transaction.</li>
          </ul>
          <p>Indirectly obtained data may include contact details, order information, license status, and consent or subscription metadata.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">7. Whether Provision of Data Is Required</h2>
          <p>Providing personal data is required for purchases, trials, and license delivery through Lemon Squeezy. If you contact us for support, the information you provide is voluntary but necessary for us to respond. You can unsubscribe from marketing emails at any time.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">8. Email Communication and Marketing Emails</h2>
          <p>If you contact us by email, we process your email address, your name if provided, and the contents of your message. Emails sent to our <code>gdagent.dev</code> addresses may be routed through <strong>Cloudflare Email Routing</strong> and stored in <strong>Proton Mail</strong>.</p>
          <p>If you purchase GDAgent or start a trial, we may use your email address to send you GDAgent updates and related emails through <strong>Sender.net</strong>.</p>
          <p><strong>Legal basis:</strong> Art. 6(1)(b) GDPR, Art. 6(1)(f) GDPR, and where required Art. 6(1)(a) GDPR.</p>
          <p>You can unsubscribe from marketing emails at any time using the unsubscribe link in the email.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">9. Cookies, Embedded Content, and Tracking</h2>
          <p>We use <strong>Umami</strong> for privacy-friendly, cookieless website analytics. Umami helps us understand aggregate traffic — such as page views, referrers, and which buttons are clicked — without setting cookies, without cross-site tracking, and without collecting information that identifies you personally. IP addresses are not stored in a form that identifies you. <strong>Legal basis:</strong> Art. 6(1)(f) GDPR (our legitimate interest in understanding and improving the Website). Because no cookies or similar device storage are used and no personal profiles are created, consent is not required.</p>
          <p>We do not use advertising trackers on this Website.</p>
          <p>The Website embeds a YouTube video via <code>youtube-nocookie.com</code>. When you load a page with that embed or interact with the player, YouTube or Google may process technical data such as your IP address and browser information and may use cookies or similar technologies on their side.</p>
          <p>If we add other non-essential cookies or third-party services in the future, we will update this Privacy Policy and obtain consent where required.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">10. No Automated Decision-Making</h2>
          <p>We do not use automated decision-making or profiling as defined in Art. 22 GDPR.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">11. Data Retention</h2>
          <ul>
            <li><strong>Website logs:</strong> retained by GitHub under GitHub's own retention rules.</li>
            <li><strong>Purchase and license data:</strong> retained by Lemon Squeezy under its own retention rules and legal obligations.</li>
            <li><strong>Support emails:</strong> retained for as long as needed to handle your request and for any legally required retention period.</li>
            <li><strong>Marketing subscription data:</strong> retained until you unsubscribe, withdraw consent, or the mailing list is discontinued, plus limited suppression data where needed to honor opt-out requests.</li>
          </ul>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">12. Recipients of Data</h2>
          <p>We share personal data only to the extent described in this policy:</p>
          <div class="overflow-x-auto">
            <table>
              <thead>
                <tr>
                  <th>Recipient</th>
                  <th>Purpose</th>
                  <th>Legal Basis</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>GitHub, Inc. (USA)</td>
                  <td>Website hosting</td>
                  <td>Art. 6(1)(f) GDPR</td>
                </tr>
                <tr>
                  <td>Umami (cookieless website analytics)</td>
                  <td>Aggregated website analytics</td>
                  <td>Art. 6(1)(f) GDPR</td>
                </tr>
                <tr>
                  <td>Lemon Squeezy, LLC (USA)</td>
                  <td>Payment processing and licensing</td>
                  <td>Art. 6(1)(b) GDPR</td>
                </tr>
                <tr>
                  <td>Cloudflare (Email Routing)</td>
                  <td>Email routing</td>
                  <td>Art. 6(1)(b) GDPR / Art. 6(1)(f) GDPR</td>
                </tr>
                <tr>
                  <td>Proton Mail / Proton AG</td>
                  <td>Email inbox hosting</td>
                  <td>Art. 6(1)(b) GDPR / Art. 6(1)(f) GDPR</td>
                </tr>
                <tr>
                  <td>Sender.net</td>
                  <td>Product update and marketing email delivery</td>
                  <td>Art. 6(1)(f) GDPR / Art. 6(1)(a) GDPR where required</td>
                </tr>
                <tr>
                  <td>YouTube / Google</td>
                  <td>Embedded video</td>
                  <td>Art. 6(1)(f) GDPR</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p>We do not sell or rent your personal data.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">13. International Data Transfers</h2>
          <p>Some recipients process data outside the EEA, including in the United States and Switzerland. Where required, such transfers are made on the basis of appropriate safeguards, such as adequacy decisions or Standard Contractual Clauses.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">14. Your Rights Under GDPR</h2>
          <p>If you are located in the European Union or European Economic Area, you have the following rights under the GDPR:</p>
          <ul>
            <li><strong>Right of access</strong> (Art. 15 GDPR): You have the right to obtain confirmation as to whether personal data concerning you is being processed and, if so, to access that data.</li>
            <li><strong>Right to rectification</strong> (Art. 16 GDPR): You have the right to request the correction of inaccurate personal data.</li>
            <li><strong>Right to erasure</strong> (Art. 17 GDPR): You have the right to request the deletion of your personal data, subject to legal retention obligations.</li>
            <li><strong>Right to restriction of processing</strong> (Art. 18 GDPR): You have the right to request restriction of processing under certain conditions.</li>
            <li><strong>Right to data portability</strong> (Art. 20 GDPR): You have the right to receive your personal data in a structured, commonly used, and machine-readable format.</li>
            <li><strong>Right to object</strong> (Art. 21 GDPR): You have the right to object to processing based on Art. 6(1)(f) GDPR (legitimate interests) at any time, for reasons relating to your particular situation.</li>
            <li><strong>Right to withdraw consent</strong> (Art. 7(3) GDPR): Where processing is based on your consent, you may withdraw that consent at any time without affecting the lawfulness of processing carried out before the withdrawal.</li>
          </ul>
          <p>To exercise any of these rights, please contact us at: <strong>info@gdagent.dev</strong></p>
          <p>We will respond to your request within one month as required by Art. 12(3) GDPR. In complex cases, this period may be extended by two further months, with notification.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">15. Right to Lodge a Complaint</h2>
          <p>You have the right to lodge a complaint with a data protection supervisory authority. The authority responsible for us is:</p>
          <p>
            <strong>Landesbeauftragte für Datenschutz und Informationsfreiheit Nordrhein-Westfalen</strong>
          </p>
          <p>Website: <a href="https://www.ldi.nrw.de" class="text-white hover:underline" target="_blank" rel="noopener">https://www.ldi.nrw.de</a></p>
          <p>You may also lodge a complaint with the supervisory authority in the EU member state of your habitual residence or place of work.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">16. Data Security</h2>
          <p>We take appropriate technical and organizational measures to protect personal data against unauthorized access, alteration, disclosure, or destruction. Our Website is served over HTTPS encryption.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">17. Children&apos;s Privacy</h2>
          <p>Our Software and Website are not directed at children under the age of 16. We do not knowingly collect personal data from children under 16. If we become aware that we have collected personal data from a child under 16, we will take steps to delete that data promptly.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">18. Changes to This Policy</h2>
          <p>We may update this Privacy Policy from time to time to reflect changes in our practices or applicable law. The updated version will be indicated by the "Last Updated" date at the top of this page. We encourage you to review this Privacy Policy periodically.</p>
        </section>

        <section>
          <h2 class="mb-4 font-mono text-xl font-medium text-white">19. Contact</h2>
          <p>If you have any questions about this Privacy Policy or wish to exercise your data protection rights, please contact us:</p>
          <p>
            <strong>Björn Feber</strong><br />
            Email: <a href="mailto:info@gdagent.dev" class="text-white hover:underline">info@gdagent.dev</a><br />
            Address: Kiebitzweg 36, 48496 Hopsten, Germany
          </p>
        </section>
      </div>

      <div id="privacy-content-de" data-policy-lang="de" class="hidden">
        <PrivacyPolicyDe />
      </div>
    </div>
  </main>
  <script>
    const policyTitle = document.getElementById("privacy-title");
    const policyUpdated = document.getElementById("privacy-updated");
    const enContent = document.getElementById("privacy-content-en");
    const deContent = document.getElementById("privacy-content-de");
    const switches = document.querySelectorAll("[data-policy-switch]");

    const labels = {
      en: {
        title: "Privacy Policy",
        updated: "Last Updated: 2026-06-23",
      },
      de: {
        title: "Datenschutzerklärung",
        updated: "Stand: 2026-06-23",
      },
    };

    function setPolicyLanguage(lang, updateHash = false) {
      const nextLang = lang === "de" ? "de" : "en";
      const isGerman = nextLang === "de";

      enContent?.classList.toggle("hidden", isGerman);
      deContent?.classList.toggle("hidden", !isGerman);

      if (policyTitle) {
        policyTitle.textContent = labels[nextLang].title;
      }

      if (policyUpdated) {
        policyUpdated.textContent = labels[nextLang].updated;
      }

      switches.forEach((button) => {
        const isActive = button.getAttribute("data-policy-switch") === nextLang;
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
        button.classList.toggle("text-[#a1a1a1]", isActive);
      });

      if (updateHash) {
        const nextHash = isGerman ? "#de" : "";
        history.replaceState(null, "", `${window.location.pathname}${nextHash}`);
      }
    }

    const initialLanguage = window.location.hash === "#de" ? "de" : "en";
    setPolicyLanguage(initialLanguage);

    switches.forEach((button) => {
      button.addEventListener("click", () => {
        const lang = button.getAttribute("data-policy-switch") || "en";
        setPolicyLanguage(lang, true);
      });
    });

    window.addEventListener("hashchange", () => {
      setPolicyLanguage(window.location.hash === "#de" ? "de" : "en");
    });
  </script>
  <Footer />
</Base>
